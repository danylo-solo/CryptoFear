<maui:MauiWinUIApplication
    x:Class="CryptoFear.WinUI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:maui="using:Microsoft.Maui"
    xmlns:local="using:CryptoFear.WinUI">

    <maui:MauiWinUIApplication.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Default">
                    <!-- Remove selected-item underline/indicator in Shell tab bar -->
                    <SolidColorBrush x:Key="NavigationViewSelectionIndicatorForeground" Color="Transparent" />

                    <!-- Increase icon box dimensions so tab icons read larger -->
                    <x:Double x:Key="NavigationViewItemOnTopIconBoxWidth">24</x:Double>
                    <x:Double x:Key="NavigationViewItemOnTopIconBoxHeight">24</x:Double>
                </ResourceDictionary>

                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="NavigationViewSelectionIndicatorForeground" Color="Transparent" />
                    <x:Double x:Key="NavigationViewItemOnTopIconBoxWidth">24</x:Double>
                    <x:Double x:Key="NavigationViewItemOnTopIconBoxHeight">24</x:Double>
                </ResourceDictionary>

                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="NavigationViewSelectionIndicatorForeground" Color="Transparent" />
                    <x:Double x:Key="NavigationViewItemOnTopIconBoxWidth">24</x:Double>
                    <x:Double x:Key="NavigationViewItemOnTopIconBoxHeight">24</x:Double>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </maui:MauiWinUIApplication.Resources>

</maui:MauiWinUIApplication>
