<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ═══════════════════════════════════════════════
         TYPOGRAPHY - Inter Font Family
         ═══════════════════════════════════════════════ -->

    <!-- Activity Indicator -->
    <Style TargetType="ActivityIndicator">
        <Setter Property="Color" Value="{DynamicResource Primary}" />
    </Style>

    <Style TargetType="IndicatorView">
        <Setter Property="IndicatorColor" Value="{DynamicResource Gray300}"/>
        <Setter Property="SelectedIndicatorColor" Value="{DynamicResource Primary}"/>
    </Style>

    <!-- Border -->
    <Style TargetType="Border">
        <Setter Property="Stroke" Value="Transparent" />
        <Setter Property="StrokeShape" Value="RoundRectangle 16"/>
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="BackgroundColor" Value="{DynamicResource Surface}"/>
    </Style>

    <Style TargetType="BoxView">
        <Setter Property="BackgroundColor" Value="Transparent" />
    </Style>

    <!-- Primary Button -->
    <Style TargetType="Button">
        <Setter Property="TextColor" Value="{DynamicResource White}" />
        <Setter Property="BackgroundColor" Value="{DynamicResource Primary}" />
        <Setter Property="FontFamily" Value="InterMedium"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="BorderWidth" Value="0"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="20,14"/>
        <Setter Property="MinimumHeightRequest" Value="48"/>
        <Setter Property="MinimumWidthRequest" Value="48"/>
        <Setter Property="CharacterSpacing" Value="0.2"/>
        <Setter Property="Shadow" Value="{x:Null}"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{DynamicResource Gray400}" />
                            <Setter Property="BackgroundColor" Value="{DynamicResource Gray200}" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="PointerOver" />
                    <VisualState x:Name="Pressed">
                        <VisualState.Setters>
                            <Setter Property="BackgroundColor" Value="{DynamicResource PrimaryDark}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <!-- Chip / Filter Button -->
    <Style x:Key="ChipButton" TargetType="Button">
        <Setter Property="TextColor" Value="{DynamicResource TextSecondary}" />
        <Setter Property="BackgroundColor" Value="{DynamicResource Gray100}" />
        <Setter Property="FontFamily" Value="InterMedium"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="BorderWidth" Value="0"/>
        <Setter Property="CornerRadius" Value="20"/>
        <Setter Property="Padding" Value="16,10"/>
        <Setter Property="MinimumHeightRequest" Value="36"/>
        <Setter Property="Shadow" Value="{x:Null}"/>
    </Style>

    <!-- Chip Selected -->
    <Style x:Key="ChipButtonSelected" TargetType="Button">
        <Setter Property="TextColor" Value="{DynamicResource White}" />
        <Setter Property="BackgroundColor" Value="{DynamicResource Primary}" />
        <Setter Property="FontFamily" Value="InterMedium"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="BorderWidth" Value="0"/>
        <Setter Property="CornerRadius" Value="20"/>
        <Setter Property="Padding" Value="16,10"/>
        <Setter Property="MinimumHeightRequest" Value="36"/>
        <Setter Property="Shadow" Value="{x:Null}"/>
    </Style>

    <!-- CheckBox -->
    <Style TargetType="CheckBox">
        <Setter Property="Color" Value="{DynamicResource Primary}" />
        <Setter Property="MinimumHeightRequest" Value="44"/>
        <Setter Property="MinimumWidthRequest" Value="44"/>
    </Style>

    <!-- Editor -->
    <Style TargetType="Editor">
        <Setter Property="TextColor" Value="{DynamicResource TextPrimary}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontFamily" Value="InterRegular"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="PlaceholderColor" Value="{DynamicResource TextMuted}" />
    </Style>

    <!-- Entry -->
    <Style TargetType="Entry">
        <Setter Property="TextColor" Value="{DynamicResource TextPrimary}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontFamily" Value="InterRegular"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="PlaceholderColor" Value="{DynamicResource TextMuted}" />
        <Setter Property="MinimumHeightRequest" Value="48"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{DynamicResource Gray400}" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Focused">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{DynamicResource TextPrimary}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <!-- Label - Default -->
    <Style TargetType="Label">
        <Setter Property="TextColor" Value="{DynamicResource TextPrimary}" />
        <Setter Property="FontFamily" Value="InterRegular" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{DynamicResource Gray400}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <!-- Typography Hierarchy -->
    <Style x:Key="DisplayLarge" TargetType="Label">
        <Setter Property="TextColor" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="FontFamily" Value="InterBold"/>
        <Setter Property="FontSize" Value="34"/>
        <Setter Property="CharacterSpacing" Value="-0.5"/>
    </Style>

    <Style x:Key="DisplayMedium" TargetType="Label">
        <Setter Property="TextColor" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="FontFamily" Value="InterBold"/>
        <Setter Property="FontSize" Value="28"/>
        <Setter Property="CharacterSpacing" Value="-0.3"/>
    </Style>

    <Style x:Key="HeadlineLarge" TargetType="Label">
        <Setter Property="TextColor" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="FontFamily" Value="InterSemiBold"/>
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="CharacterSpacing" Value="-0.2"/>
    </Style>

    <Style x:Key="HeadlineMedium" TargetType="Label">
        <Setter Property="TextColor" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="FontFamily" Value="InterSemiBold"/>
        <Setter Property="FontSize" Value="20"/>
    </Style>

    <Style x:Key="TitleLarge" TargetType="Label">
        <Setter Property="TextColor" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="FontFamily" Value="InterSemiBold"/>
        <Setter Property="FontSize" Value="18"/>
    </Style>

    <Style x:Key="TitleMedium" TargetType="Label">
        <Setter Property="TextColor" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="FontFamily" Value="InterSemiBold"/>
        <Setter Property="FontSize" Value="16"/>
    </Style>

    <Style x:Key="BodyLarge" TargetType="Label">
        <Setter Property="TextColor" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="FontFamily" Value="InterRegular"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="LineHeight" Value="1.5"/>
    </Style>

    <Style x:Key="BodyMedium" TargetType="Label">
        <Setter Property="TextColor" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="FontFamily" Value="InterRegular"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>

    <Style x:Key="LabelLarge" TargetType="Label">
        <Setter Property="TextColor" Value="{DynamicResource TextSecondary}"/>
        <Setter Property="FontFamily" Value="InterMedium"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>

    <Style x:Key="LabelSmall" TargetType="Label">
        <Setter Property="TextColor" Value="{DynamicResource TextSecondary}"/>
        <Setter Property="FontFamily" Value="InterRegular"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <!-- Picker -->
    <Style TargetType="Picker">
        <Setter Property="TextColor" Value="{DynamicResource TextPrimary}" />
        <Setter Property="TitleColor" Value="{DynamicResource TextMuted}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontFamily" Value="InterRegular"/>
        <Setter Property="FontSize" Value="15" />
        <Setter Property="MinimumHeightRequest" Value="48"/>
    </Style>

    <!-- ProgressBar -->
    <Style TargetType="ProgressBar">
        <Setter Property="ProgressColor" Value="{DynamicResource Primary}" />
    </Style>

    <!-- RefreshView -->
    <Style TargetType="RefreshView">
        <Setter Property="RefreshColor" Value="{DynamicResource Primary}" />
    </Style>

    <!-- SearchBar -->
    <Style TargetType="SearchBar">
        <Setter Property="TextColor" Value="{DynamicResource TextPrimary}" />
        <Setter Property="PlaceholderColor" Value="{DynamicResource TextMuted}" />
        <Setter Property="CancelButtonColor" Value="{DynamicResource Primary}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontFamily" Value="InterRegular" />
        <Setter Property="FontSize" Value="15" />
    </Style>

    <!-- Shadow -->
    <Style TargetType="Shadow">
        <Setter Property="Radius" Value="12" />
        <Setter Property="Opacity" Value="0.2" />
        <Setter Property="Brush" Value="{DynamicResource ShadowColor}" />
        <Setter Property="Offset" Value="0,4" />
    </Style>

    <!-- Slider -->
    <Style TargetType="Slider">
        <Setter Property="MinimumTrackColor" Value="{DynamicResource Primary}" />
        <Setter Property="MaximumTrackColor" Value="{DynamicResource Gray200}" />
        <Setter Property="ThumbColor" Value="{DynamicResource Primary}" />
    </Style>

    <!-- Switch -->
    <Style TargetType="Switch">
        <Setter Property="OnColor" Value="{DynamicResource Primary}" />
        <Setter Property="ThumbColor" Value="{DynamicResource White}" />
    </Style>

    <!-- Page -->
    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="BackgroundColor" Value="{DynamicResource Background}" />
    </Style>

    <Style TargetType="Shell" ApplyToDerivedTypes="True">
        <Setter Property="Shell.BackgroundColor" Value="{DynamicResource Background}" />
        <Setter Property="Shell.ForegroundColor" Value="{DynamicResource TextPrimary}" />
        <Setter Property="Shell.TitleColor" Value="{DynamicResource TextPrimary}" />
        <Setter Property="Shell.DisabledColor" Value="{DynamicResource Gray400}" />
        <Setter Property="Shell.UnselectedColor" Value="{DynamicResource TextMuted}" />
        <Setter Property="Shell.NavBarHasShadow" Value="False" />
        <Setter Property="Shell.TabBarBackgroundColor" Value="{DynamicResource Surface}" />
        <Setter Property="Shell.TabBarForegroundColor" Value="{DynamicResource Primary}" />
        <Setter Property="Shell.TabBarTitleColor" Value="{DynamicResource Primary}" />
        <Setter Property="Shell.TabBarUnselectedColor" Value="{DynamicResource TextMuted}" />
    </Style>

    <Style TargetType="NavigationPage">
        <Setter Property="BarBackgroundColor" Value="{DynamicResource Background}" />
        <Setter Property="BarTextColor" Value="{DynamicResource TextPrimary}" />
        <Setter Property="IconColor" Value="{DynamicResource Primary}" />
    </Style>

    <!-- ═══════════════════════════════════════════════
         CARD STYLES
         ═══════════════════════════════════════════════ -->

    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{DynamicResource Surface}"/>
        <Setter Property="Stroke" Value="Transparent"/>
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="StrokeShape" Value="RoundRectangle 0"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="Shadow" Value="{x:Null}"/>
    </Style>

    <Style x:Key="ElevatedCard" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{DynamicResource Surface}"/>
        <Setter Property="Stroke" Value="Transparent"/>
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="StrokeShape" Value="RoundRectangle 20"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="Shadow">
            <Shadow Brush="{DynamicResource ShadowColor}" Offset="0,3" Radius="12" Opacity="0.16"/>
        </Setter>
    </Style>

    <Style x:Key="ModernCard" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{DynamicResource Surface}"/>
        <Setter Property="Stroke" Value="{DynamicResource Border}"/>
        <Setter Property="StrokeThickness" Value="1"/>
        <Setter Property="StrokeShape" Value="RoundRectangle 20"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="Shadow">
            <Shadow Brush="{DynamicResource ShadowColor}" Offset="0,4" Radius="14" Opacity="0.16"/>
        </Setter>
    </Style>

    <Style x:Key="InteractiveCard" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{DynamicResource Surface}"/>
        <Setter Property="Stroke" Value="{DynamicResource Border}"/>
        <Setter Property="StrokeThickness" Value="1"/>
        <Setter Property="StrokeShape" Value="RoundRectangle 20"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="Shadow">
            <Shadow Brush="{DynamicResource ShadowColor}" Offset="0,3" Radius="12" Opacity="0.14"/>
        </Setter>
    </Style>

    <Style x:Key="StatCard" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{DynamicResource SurfaceElevated}"/>
        <Setter Property="Stroke" Value="{DynamicResource Border}"/>
        <Setter Property="StrokeThickness" Value="1"/>
        <Setter Property="StrokeShape" Value="RoundRectangle 20"/>
        <Setter Property="Padding" Value="20,24"/>
        <Setter Property="Shadow">
            <Shadow Brush="{DynamicResource ShadowColor}" Offset="0,4" Radius="14" Opacity="0.18"/>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════
         UTILITY STYLES
         ═══════════════════════════════════════════════ -->

    <Style x:Key="SectionHeader" TargetType="Label">
        <Setter Property="TextColor" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="FontFamily" Value="InterSemiBold"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="CharacterSpacing" Value="-0.1"/>
    </Style>

    <Style x:Key="PageTitle" TargetType="Label">
        <Setter Property="TextColor" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="FontFamily" Value="InterBold"/>
        <Setter Property="FontSize" Value="28"/>
        <Setter Property="CharacterSpacing" Value="-0.5"/>
    </Style>

    <Style x:Key="CardTitle" TargetType="Label">
        <Setter Property="TextColor" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="FontFamily" Value="InterSemiBold"/>
        <Setter Property="FontSize" Value="16"/>
    </Style>

    <Style x:Key="CardSubtitle" TargetType="Label">
        <Setter Property="TextColor" Value="{DynamicResource TextSecondary}"/>
        <Setter Property="FontFamily" Value="InterRegular"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>

    <Style x:Key="SoftBadge" TargetType="Border">
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="StrokeShape" Value="RoundRectangle 8"/>
        <Setter Property="Padding" Value="10,6"/>
    </Style>

</ResourceDictionary>
