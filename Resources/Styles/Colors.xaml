<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Background -->
    <Color x:Key="Background">#08080F</Color>
    <Color x:Key="BackgroundAlt">#0E0E18</Color>

    <!-- Surfaces -->
    <Color x:Key="Surface">#14142A</Color>
    <Color x:Key="SurfaceElevated">#1C1C36</Color>
    <Color x:Key="SurfaceContainer">#242444</Color>

    <!-- Primary - Washed Purple -->
    <Color x:Key="Primary">#8B7EC8</Color>
    <Color x:Key="PrimaryDark">#6B5FA8</Color>
    <Color x:Key="PrimaryLight">#B3A6E0</Color>
    <Color x:Key="PrimaryContainer">#2A2450</Color>

    <!-- Text -->
    <Color x:Key="TextPrimary">#E8E6F0</Color>
    <Color x:Key="TextSecondary">#7A7890</Color>
    <Color x:Key="TextMuted">#4A4860</Color>

    <!-- Borders -->
    <Color x:Key="Border">#2A2A44</Color>
    <Color x:Key="BorderLight">#363654</Color>

    <!-- Status -->
    <Color x:Key="Success">#4ADE80</Color>
    <Color x:Key="Danger">#F87171</Color>
    <Color x:Key="Warning">#FBBF24</Color>

    <!-- Fear & Greed Spectrum -->
    <Color x:Key="FearExtreme">#F87171</Color>
    <Color x:Key="Fear">#FB923C</Color>
    <Color x:Key="Neutral">#FBBF24</Color>
    <Color x:Key="Greed">#4ADE80</Color>
    <Color x:Key="GreedExtreme">#22C55E</Color>

    <!-- Base -->
    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#000000</Color>

    <!-- Gray Scale -->
    <Color x:Key="Gray100">#1C1C30</Color>
    <Color x:Key="Gray200">#2A2A44</Color>
    <Color x:Key="Gray300">#3A3A58</Color>
    <Color x:Key="Gray400">#4A4860</Color>
    <Color x:Key="Gray500">#5A5878</Color>
    <Color x:Key="Gray600">#7A7890</Color>
    <Color x:Key="Gray700">#9A98B0</Color>
    <Color x:Key="Gray800">#BAB8D0</Color>
    <Color x:Key="Gray900">#E8E6F0</Color>

    <!-- Solid Color Brushes -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDark}"/>
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="{StaticResource PrimaryLight}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource Surface}"/>
    <SolidColorBrush x:Key="SurfaceElevatedBrush" Color="{StaticResource SurfaceElevated}"/>
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource Background}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>

    <!-- Gradient Brushes -->
    <LinearGradientBrush x:Key="PrimaryGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource Primary}" Offset="0.0"/>
        <GradientStop Color="{StaticResource PrimaryDark}" Offset="1.0"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="HeroGradientBrush" StartPoint="0,0" EndPoint="0.5,1">
        <GradientStop Color="#1A1840" Offset="0.0"/>
        <GradientStop Color="#0E0E18" Offset="1.0"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="CardGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource Surface}" Offset="0.0"/>
        <GradientStop Color="{StaticResource SurfaceElevated}" Offset="1.0"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="GaugeGlowBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#F87171" Offset="0.0"/>
        <GradientStop Color="#FB923C" Offset="0.25"/>
        <GradientStop Color="#FBBF24" Offset="0.5"/>
        <GradientStop Color="#4ADE80" Offset="0.75"/>
        <GradientStop Color="#22C55E" Offset="1.0"/>
    </LinearGradientBrush>

</ResourceDictionary>
