<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="CryptoFear.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:CryptoFear.Views"
    Title="CryptoFear"
    Shell.NavBarIsVisible="False"
    Shell.BackgroundColor="{StaticResource Background}"
    FlyoutBehavior="Disabled">

    <TabBar>
        <ShellContent
            Title=""
            Icon="home.png"
            ContentTemplate="{DataTemplate views:HomePage}"
            Route="home" />

        <ShellContent
            Title=""
            Icon="chart.png"
            ContentTemplate="{DataTemplate views:ChartPage}"
            Route="chart" />

        <ShellContent
            Title=""
            Icon="view.png"
            ContentTemplate="{DataTemplate views:WatchPage}"
            Route="watch" />
    </TabBar>

</Shell>
